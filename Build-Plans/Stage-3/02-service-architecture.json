  "architecture_decisions": [
    {
      "decision_id": "ARCH-DEC-004",
      "decision": "Use modular monolith service boundaries for MVP with explicit domain ownership.",
      "rationale": "The MVP benefits from clear boundaries without distributed-service overhead."
    },
    {
      "decision_id": "ARCH-DEC-005",
      "decision": "Keep Contribution Reference separate from Ledger.",
      "rationale": "Public contribution provider references are not trip expenses and must not mix with private event balances."
    }
